{
  "name": "SnapKitty Nemotron Harness Trust Deed",
  "version": "0.1.0",
  "authority": "SnapKitty Collective",
  "model_role": "untrusted_compute_resource",
  "default_mode": "executor",
  "core_rules": {
    "questions_are_expensive": true,
    "execution_is_default": true,
    "uncertainty_classification": ["PROVED", "WITNESSED", "SPEC", "OBLIGATION"],
    "raw_output_is_not_action": true,
    "receipt_required": true
  },
  "allowed_syscalls": {
    "emojicode_persona": {
      "enabled": true,
      "requires_approval": false,
      "requires_receipt": true
    },
    "prolog_gate": {
      "enabled": true,
      "requires_approval": false,
      "requires_receipt": true
    },
    "lean_gate": {
      "enabled": true,
      "requires_approval": false,
      "requires_receipt": true
    },
    "file_read": {
      "enabled": true,
      "requires_approval": false,
      "requires_receipt": true
    },
    "file_write": {
      "enabled": false,
      "requires_approval": true,
      "requires_receipt": true
    },
    "bash_exec": {
      "enabled": false,
      "requires_approval": true,
      "requires_receipt": true
    },
    "curl_fetch": {
      "enabled": false,
      "requires_approval": true,
      "requires_receipt": true
    },
    "tavily_search": {
      "enabled": false,
      "requires_approval": false,
      "requires_receipt": true,
      "label": "RETRIEVAL_UNTRUSTED"
    },
    "google_search": {
      "enabled": false,
      "requires_approval": false,
      "requires_receipt": true,
      "label": "RETRIEVAL_UNTRUSTED"
    },
    "receipt_seal": {
      "enabled": true,
      "requires_approval": false,
      "requires_receipt": true
    },
    "executor_mode": {
      "enabled": true,
      "requires_approval": false,
      "requires_receipt": true
    },
    "kernel_verify": {
      "enabled": true,
      "requires_approval": false,
      "requires_receipt": true
    },
    "ere_check": {
      "enabled": true,
      "requires_approval": false,
      "requires_receipt": true
    },
    "worm_seal_required": {
      "enabled": true,
      "requires_approval": false,
      "requires_receipt": true
    },
    "build_receipt": {
      "enabled": true,
      "requires_approval": false,
      "requires_receipt": true
    },
    "reject_unsealed": {
      "enabled": true,
      "requires_approval": false,
      "requires_receipt": true
    },
    "reject_untrusted": {
      "enabled": true,
      "requires_approval": false,
      "requires_receipt": true
    },
    "build_check": {
      "enabled": true,
      "requires_approval": false,
      "requires_receipt": true
    }
  },
  "denied_commands": [
    "rm -rf",
    "sudo",
    "cat ~/.ssh",
    "cat ~/.env",
    "git push --force",
    "chmod 777",
    "curl | sh"
  ]
}
