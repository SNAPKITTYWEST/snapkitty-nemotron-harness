{
  "name": "snapkitty-nemotron-harness",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run web\"",
    "server": "cd packages/server && npm run dev",
    "web": "cd apps/web && npm run dev",
    "build": "npm run build:web",
    "build:web": "cd apps/web && npm run build",
    "typecheck": "cd packages/harness && npm run typecheck"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
